    <h2 class="pt-12 text-2xl font-normal sm:text-[2rem] md:pt-0 md:pb-2 md:text-[1.8rem] lg:text-[2rem] xl:text-[2.2rem]" data-i18n="aboutMe.aboutMeTitle">
