---
---
<div class="text-center my-4 py-2 2xl:pt-6" id="skills">
    <h2 class="text-3xl md:text-[1.8rem] text-neutral-100" data-i18n="skills.skillsTitle">My <span class="font-bold text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-500">Skills</span></h2>

    <ul class="grid grid-cols-2 lg:grid-cols-3 gap-4 py-8 font-semibold text-lg md:text-[1rem] text-neutral-300">
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-html5-plain colored text-6xl mb-4"></i><span>HTML</span></li>
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-css3-plain colored text-6xl mb-4"></i><span>CSS</span></li>
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-react-original colored text-6xl mb-4"></i><span>React</span></li>
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-express-original text-white text-6xl mb-4"></i><span>Express</span></li>
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-nodejs-plain colored text-6xl mb-4"></i><span>Node.js</span></li>
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-python-plain colored text-6xl mb-4"></i><span>Python</span></li>
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-flask-original text-white text-6xl mb-4"></i><span>Flask</span></li>
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-mysql-plain colored text-6xl mb-4"></i><span>SQL</span></li>
        <li class="flex flex-col justify-center items-center border border-neutral-800 rounded-xl bg-neutral-900/40 p-6 transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_10px_20px_rgba(255,255,255,0.05)] hover:border-neutral-600 hover:bg-neutral-800/60"><i class="devicon-git-plain colored text-6xl mb-4"></i><span>Git</span></li>
    </ul>
</div>

