---
import Email from '@/assets/Email.astro'
import GitHub from '@/assets/GitHub.astro'
import LinkedIn from '@/assets/LinkedIn.astro'
---

<div class="w-full overflow-x-hidden">
  <div class="flex flex-col md:flex-row-reverse md:mt-[4rem] 2xl:mt-[6rem]">
    
    <!-- Imagen -->
    <div class="ml-auto mr-auto flex justify-center mb-[5%] overflow-hidden shadow-xl rounded-[5%]">
      <img src="logo.png" alt="Logo"
        class="w-[80%] max-w-[18rem] h-auto p-2 rounded-full object-cover 
               sm:max-w-[20rem] md:max-w-[23rem] lg:max-w-[26rem] 
               xl:max-w-[28rem] 2xl:max-w-[32rem]" />
    </div>

    <!-- Texto -->
    <section class="text-center ml-auto mr-auto max-w-[90%] md:max-w-none md:w-[50%] lg:mr-0 2xl:ml-20 
        md:flex md:flex-col md:items-start md:justify-center md:text-start">
      
      <div class="border-black border-2 p-2 md:border-none md:pl-0 w-full">
        <div class="flex flex-col items-center md:items-start w-full text-balance break-words overflow-hidden">
          <h1 class="text-[1.4rem] sm:text-[1.6rem] md:text-[1.9rem] 
                     lg:text-[2.2rem] xl:text-[2.6rem] 2xl:text-[3rem]"
              data-i18n="hero.greeting"></h1>

          <h2 class="flex flex-col text-[1.4rem] sm:text-[1.6rem] md:text-[1.9rem] 
                     lg:text-[2.2rem] xl:text-[2.6rem] 2xl:text-[3rem] leading-tight">
            <span class="desarrollador font-bold" data-i18n="hero.professionLine1"></span>
            <span class="font-bold" data-i18n="hero.professionLine2"></span>
          </h2>

          <h3 class="text-[1.4rem] sm:text-[1.6rem] md:text-[1.9rem] 
                     lg:text-[2.2rem] xl:text-[2.6rem] 2xl:text-[3rem]"
              data-i18n="hero.location"></h3>
        </div>
      </div>

      <p class="py-4 text-zinc-500 whitespace-normal break-words 
                sm:text-[1rem] sm:text-center md:text-start md:text-[0.9rem] 
                lg:w-[76%] xl:text-[1.2rem] 2xl:text-[1.35rem]"
         data-i18n="hero.introText"></p>
    </section>
  </div>

  <!-- Enlaces sociales -->
  <section class="p-4 md:flex md:pl-0 md:pt-0">
    <ul class="flex justify-center gap-4 mt-4 mb-2">
      <a href="mailto:sasha.stankevich223@gmail.com" target="_blank" class="w-11 border-2 border-black rounded p-2">
        <Email />
      </a>
      <a href="https://github.com/al3-rom" target="_blank" class="w-11 border-2 border-black rounded p-2">
        <GitHub />
      </a>
      <a href="https://www.linkedin.com/in/alejandro-romero-stankevich-b42b30241/" target="_blank" class="w-11 border-2 border-black rounded p-2">
        <LinkedIn />
      </a>
    </ul>
  </section>

  <!-- Botón CV (solo en móvil) -->
  <section class="text-[1.3rem] p-4 pb-12 text-center block md:hidden">
    <a id="cv-download" href="/Curriculum_CV_ES.pdf" download="CV_Alejandro_ES.pdf"
       class="mt-3 inline-block bg-black text-white text-sm px-4 py-2 rounded shadow-sm group"
       data-i18n="hero.downloadCV">
      Descargar CV
      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
           viewBox="0 0 24 24" stroke="currentColor"
           class="w-5 h-5 opacity-0 group-hover:opacity-100 translate-x-[-10px] 
                  group-hover:translate-x-0 transition-all duration-300">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 4v12" />
      </svg>
    </a>
  </section>
</div>

<!-- Script cambio de CV por idioma -->
<script type="module">
  document.addEventListener("DOMContentLoaded", () => {
    const selector = document.getElementById("lang-selector");
    const cvDownloadButton = document.getElementById("cv-download");

    function updateCVDownloadLink(lang) {
      if (lang === "en" || lang === "ru") {
        cvDownloadButton.setAttribute("href", "/Curriculum_CV_EN.pdf");
        cvDownloadButton.setAttribute("download", "CV_Alejandro_EN.pdf");
      } else {
        cvDownloadButton.setAttribute("href", "/Curriculum_CV_ES.pdf");
        cvDownloadButton.setAttribute("download", "CV_Alejandro_ES.pdf");
      }
    }

    const savedLang = localStorage.getItem("lang") || "es";
    if (selector) selector.value = savedLang;
    updateCVDownloadLink(savedLang);

    if (selector) {
      selector.addEventListener("change", (e) => {
        const lang = e.target.value;
        localStorage.setItem("lang", lang);
        updateCVDownloadLink(lang);
      });
    }
  });
</script>

<style>
  :global(.desarrollador) {
    -webkit-text-fill-color: transparent;
    -webkit-text-stroke: 1px black;
    text-stroke: 1px rgb(255, 255, 255);
  }

  :global(.blinking-text) {
    animation: blink 1.5s infinite;
  }

  @keyframes blink {
    0% { opacity: 1; }
    50% { opacity: 0; }
    100% { opacity: 1; }
  }
</style>
