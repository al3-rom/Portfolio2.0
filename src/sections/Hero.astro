---
import Email from '@/assets/Email.astro'
import GitHub from '@/assets/GitHub.astro'
import LinkedIn from '@/assets/LinkedIn.astro'
---

<div class="w-full overflow-x-hidden">
  <div class="flex flex-col-reverse md:flex-row md:justify-between md:mt-[4rem] 2xl:mt-[6rem] items-center gap-8 md:gap-4">
    
    <!-- Texto -->
    <section class="text-center md:text-left w-[95%] sm:w-[90%] md:w-[55%] lg:w-[60%] flex flex-col items-center md:items-start justify-center">
      
      <!-- Location Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-neutral-900/50 border border-neutral-800 mb-6 shadow-sm backdrop-blur-sm">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" class="w-4 h-4 text-emerald-400">
          <path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" />
          <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z" />
        </svg>
        <span class="text-sm font-medium text-neutral-300" data-i18n="hero.location"></span>
      </div>

      <h1 class="text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-neutral-100 mb-2" data-i18n="hero.greeting"></h1>

      <h2 class="flex flex-col text-5xl sm:text-6xl md:text-6xl lg:text-[5rem] xl:text-[6rem] font-extrabold tracking-tighter leading-[1.1] mb-6">
        <span class="desarrollador" data-i18n="hero.professionLine1"></span>
        <span class="text-white" data-i18n="hero.professionLine2"></span>
      </h2>

      <p class="text-neutral-400 text-[1.05rem] sm:text-lg md:text-xl max-w-2xl leading-relaxed mb-8 text-pretty" data-i18n="hero.introText"></p>

      <!-- Enlaces sociales -->
      <ul class="flex justify-center md:justify-start gap-4">
        <a href="mailto:sasha.stankevich233@gmail.com" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-full bg-neutral-900 border border-neutral-800 hover:border-neutral-500 hover:bg-neutral-800 transition-all duration-300 shadow-lg">
          <Email />
        </a>
        <a href="https://github.com/al3-rom" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-full bg-neutral-900 border border-neutral-800 hover:border-neutral-500 hover:bg-neutral-800 transition-all duration-300 shadow-lg">
          <GitHub />
        </a>
        <a href="https://www.linkedin.com/in/alejandro-romero-stankevich-b42b30241/" target="_blank" class="w-12 h-12 flex items-center justify-center rounded-full bg-neutral-900 border border-neutral-800 hover:border-neutral-500 hover:bg-neutral-800 transition-all duration-300 shadow-lg">
          <LinkedIn />
        </a>
      </ul>
    </section>

    <!-- Imagen -->
    <div class="w-full md:w-[45%] lg:w-[40%] flex justify-center relative mt-6 md:mt-0">
      <div class="relative group w-[65%] sm:w-[50%] md:w-[85%] lg:w-[80%] max-w-[400px] aspect-square">
        <div class="absolute -inset-4 bg-gradient-to-tr from-blue-600 to-purple-600 rounded-full blur-2xl opacity-30 group-hover:opacity-50 transition duration-700"></div>
        
        <div class="relative w-full h-full rounded-full border border-white/10 p-[6px] sm:p-2 bg-neutral-950/60 backdrop-blur-xl shadow-2xl transition-transform duration-500 group-hover:scale-[1.02]">
          <div class="w-full h-full rounded-full overflow-hidden [clip-path:circle(50%)]">
            <img src="logo.png" alt="Logo" class="w-full h-full object-cover scale-[1.05]" />
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Botón CV (solo en móvil) -->
  <section class="text-[1.3rem] p-4 pb-12 text-center block md:hidden">
    <a id="cv-download" href="/CV Profesional Junior Full Stack Developer.pdf" download="CV_Alejandro_ES.pdf"
       class="mt-3 inline-flex items-center justify-center gap-2 bg-white text-black font-semibold text-sm px-6 py-3 rounded-full shadow-lg group hover:bg-neutral-200 transition-all duration-300"
       data-i18n="hero.downloadCV">
      Descargar CV
      <svg xmlns="http://www.w3.org/2000/svg" fill="none"
           viewBox="0 0 24 24" stroke="currentColor"
           class="w-5 h-5 opacity-0 group-hover:opacity-100 translate-x-[-10px] 
                  group-hover:translate-x-0 transition-all duration-300">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 16v2a2 2 0 002 2h12a2 2 0 002-2v-2M7 10l5 5 5-5M12 4v12" />
      </svg>
    </a>
  </section>
</div>

<!-- Script cambio de CV por idioma -->
<script type="module">
  document.addEventListener("DOMContentLoaded", () => {
    const selector = document.getElementById("lang-selector");
    const cvDownloadButton = document.getElementById("cv-download");

    function updateCVDownloadLink(lang) {
      if (!cvDownloadButton) return;
      if (lang === "en") {
        cvDownloadButton.setAttribute("href", "/CV Profesional Junior Full Stack Developer_English.pdf");
        cvDownloadButton.setAttribute("download", "CV_Alejandro_EN.pdf");
      } else if (lang === "ru") {
        cvDownloadButton.setAttribute("href", "/CV Profesional Junior Full Stack Developer_Russian.pdf");
        cvDownloadButton.setAttribute("download", "CV_Alejandro_RU.pdf");
      } else {
        cvDownloadButton.setAttribute("href", "/CV Profesional Junior Full Stack Developer.pdf");
        cvDownloadButton.setAttribute("download", "CV_Alejandro_ES.pdf");
      }
    }

    const savedLang = localStorage.getItem("lang") || "es";
    if (selector) selector.value = savedLang;
    updateCVDownloadLink(savedLang);

    if (selector) {
      selector.addEventListener("change", (e) => {
        const lang = e.target.value;
        localStorage.setItem("lang", lang);
        updateCVDownloadLink(lang);
      });
    }
  });
</script>

<style>
  :global(.desarrollador) {
    background: linear-gradient(to right, #4facfe 0%, #00f2fe 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  :global(.blinking-text) {
    animation: blink 1.5s infinite;
  }

  @keyframes blink {
    0% { opacity: 1; }
    50% { opacity: 0; }
    100% { opacity: 1; }
  }
</style>
